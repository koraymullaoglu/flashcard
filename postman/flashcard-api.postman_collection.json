{
  "info": {
    "name": "Flashcard API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "let token = pm.environment.get('token');",
          "if (token) {",
          "  pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + token });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Register",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.environment.set('username', 'pm-' + Date.now());",
              "pm.environment.set('password', 'pm-pass');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('latency < 500ms', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(500);",
              "});",
              "",
              "let schema = {",
              "  type: 'object',",
              "  required: ['data'],",
              "  properties: {",
              "    data: {",
              "      type: 'object',",
              "      required: ['id', 'username'],",
              "      properties: {",
              "        id: { type: 'number' },",
              "        username: { type: 'string' }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('schema valid', function () {",
              "  pm.expect(tv4.validate(pm.response.json(), schema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": "{{base_url}}/api/auth/register"
      }
    },
    {
      "name": "Login",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.environment.get('username')) {",
              "  pm.environment.set('username', 'pm-' + Date.now());",
              "  pm.environment.set('password', 'pm-pass');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('latency < 500ms', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(500);",
              "});",
              "",
              "let schema = {",
              "  type: 'object',",
              "  required: ['data'],",
              "  properties: {",
              "    data: {",
              "      type: 'object',",
              "      required: ['token'],",
              "      properties: {",
              "        token: { type: 'string' }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('schema valid', function () {",
              "  pm.expect(tv4.validate(pm.response.json(), schema)).to.be.true;",
              "});",
              "",
              "pm.environment.set('token', pm.response.json().data.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": "{{base_url}}/api/auth/login"
      }
    },
    {
      "name": "Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('latency < 200ms', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(200);",
              "});",
              "",
              "let schema = {",
              "  type: 'object',",
              "  required: ['status'],",
              "  properties: {",
              "    status: { type: 'string' }",
              "  }",
              "};",
              "pm.test('schema valid', function () {",
              "  pm.expect(tv4.validate(pm.response.json(), schema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health"
      }
    },
